# Environment Variables — Salin file ini ke .env dan isi nilainya

# URL koneksi database MySQL
# Format: mysql+pymysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# Untuk Vercel, gunakan database cloud seperti:
# - PlanetScale: mysql+pymysql://user:pass@aws.connect.psdb.cloud/agency_db?ssl_ca=/etc/ssl/certs/ca-certificates.crt
# - Railway:     mysql+pymysql://user:pass@containers-us-west-xxx.railway.app:PORT/railway
# - Filess.io (free MySQL): mysql+pymysql://user:pass@host:3306/agency_db
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/agency_db

# Secret key untuk hashing & JWT (ganti dengan string panjang random)
SECRET_KEY=ganti_dengan_string_sangat_rahasia_minimal_32_karakter
